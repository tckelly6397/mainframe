# Required
DISCORD_TOKEN=your-bot-token-here
ALLOWED_USER_ID=your-discord-user-id

# Bot identity (shown in Claude's system prompt)
BOT_OWNER=YourName
SERVER_NAME=my-server

# Channel organization (optional — leave blank for mention-based activation)
# Right-click channel > Copy Channel ID
MAIN_CHANNEL_ID=
ADMIN_CHANNEL_ID=

# Path overrides (optional — auto-detected by default)
# APPS_DIR=/home/you/apps
# CLAUDE_PATH=/home/you/.local/bin/claude
# BOT_HOME=/home/you
